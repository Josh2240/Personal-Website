# docker-compose.override.yml
# This file is loaded automatically by docker-compose and overrides docker-compose.yml
# Use this for local development settings
# DO NOT commit this file to git if it contains sensitive information

version: '3.8'

services:
  app:
    # Mount source code for hot reload during development
    volumes:
      - .:/app
      - /app/node_modules

  db:
    # Expose MySQL port for local database tools
    ports:
      - "3306:3306"
